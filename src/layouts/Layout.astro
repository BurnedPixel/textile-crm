---
import '../styles/global.css';
import SyncStatus from '../components/SyncStatus.tsx';
import { BRAND } from '../../brand.mjs';

interface Props {
  title: string;
  active?: string;
}

const { title, active } = Astro.props;
const isDev = import.meta.env.DEV;

const navItems = [
  { label: 'Panel',         href: '/',             key: 'p', hint: 'g p', icon: 'grid' },
  { label: 'Venta',         href: '/venta',        key: 'v', hint: 'g v', icon: 'cart' },
  { label: 'Ingreso',       href: '/ingreso',      key: 'i', hint: 'g i', icon: 'plus' },
  { label: 'Clientes',      href: '/clientes',     key: 'c', hint: 'g c', icon: 'person' },
  { label: 'Gastos',        href: '/gastos',       key: 'g', hint: 'g g', icon: 'receipt' },
  { label: 'Ajustes',       href: '/configuracion',key: 'o', hint: 'g o', icon: 'settings' },
];

const icons: Record<string, string> = {
  grid:     `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>`,
  cart:     `<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>`,
  plus:     `<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>`,
  person:   `<path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  receipt:  `<path d="M14 2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2V4a2 2 0 00-2-2z"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/>`,
  settings: `<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>`,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} — {BRAND.name}</title>

    {/* AUTH GATE — runs before paint, no flash */}
    <script is:inline define:vars={{ dev: isDev, userKey: `${BRAND.dbName}:user` }}>
      if (!dev && !localStorage.getItem(userKey) && location.pathname !== '/login') {
        location.replace('/login');
      }
    </script>
  </head>

  <body>
    {/* SELVAGE RAIL — left column on desktop, bottom bar on phones */}
    <nav class="rail" aria-label="Navegación principal">
      {/* Wordmark */}
      <div class="rail-brand">
        <a href="/" style="text-decoration:none;" title={BRAND.name}>
          <img src="/favicon.svg" width="28" height="28" alt={BRAND.name} />
        </a>
      </div>

      {/* Nav items */}
      {navItems.map((item) => {
        const isActive = active === item.href || (item.href !== '/' && Astro.url.pathname.startsWith(item.href));
        return (
          <a
            href={item.href}
            title={item.label}
            class="rail-link"
            style={`
              color:${isActive ? 'var(--color-dye)' : 'var(--color-thread)'};
              background:${isActive ? 'rgba(181,23,92,0.10)' : 'transparent'};
            `}
            aria-current={isActive ? 'page' : undefined}
          >
            {isActive && (
              <span class="rail-active-bar" aria-hidden="true" />
            )}
            <svg
              width="20" height="20" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="1.75"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
              set:html={icons[item.icon]}
            />
            <span class="rail-label">
              {item.label.length > 8 ? item.label.slice(0, 7) + '…' : item.label}
            </span>
            <span class="rail-hint">
              {item.hint}
            </span>
          </a>
        );
      })}

      {/* Selvage dot pattern — right edge decoration */}
      <div class="rail-dots" aria-hidden="true" />

      {/* Spacer */}
      <div style="flex:1;" />

      {/* SyncStatus island — bottom of rail (desktop) / top bar (phone) */}
      <SyncStatus client:only="react" />

      {/* Hamburger menu — phone only (rail-links hidden there) */}
      <details class="rail-menu">
        <summary aria-label="Menú de navegación">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
          </svg>
        </summary>
        <div class="menu-panel">
          {navItems.map((item) => {
            const isActive = active === item.href || (item.href !== '/' && Astro.url.pathname.startsWith(item.href));
            return (
              <a
                href={item.href}
                class="menu-link"
                style={`
                  color:${isActive ? 'var(--color-dye)' : 'var(--color-greige)'};
                  background:${isActive ? 'rgba(181,23,92,0.12)' : 'transparent'};
                `}
                aria-current={isActive ? 'page' : undefined}
              >
                <svg
                  width="20" height="20" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="1.75"
                  stroke-linecap="round" stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={icons[item.icon]}
                />
                {item.label}
              </a>
            );
          })}
        </div>
      </details>
    </nav>

    {/* MAIN CONTENT */}
    <main class="content">
      <slot />
    </main>

    <style>
      body { display: flex; min-height: 100vh; }

      .rail {
        position: fixed; top: 0; left: 0; bottom: 0; width: 76px; z-index: 50;
        background-color: var(--color-ink);
        display: flex; flex-direction: column; align-items: center;
        padding: 1rem 0 0.75rem; gap: 0.25rem;
        border-right: 1px solid rgba(255,255,255,0.06);
      }
      .rail-brand { margin-bottom: 1.25rem; text-align: center; }
      .rail-link {
        display: flex; flex-direction: column; align-items: center; gap: 2px;
        width: 64px; padding: 8px 4px; border-radius: 6px; text-decoration: none;
        min-height: 44px; justify-content: center; position: relative;
        transition: color 0.15s, background 0.15s;
      }
      .rail-active-bar {
        position: absolute; left: 0; top: 25%; bottom: 25%; width: 3px;
        background: var(--color-dye); border-radius: 0 2px 2px 0;
      }
      .rail-label {
        font-size: 10px; font-weight: 600; letter-spacing: 0.06em;
        text-transform: uppercase; line-height: 1; font-family: var(--font-sans);
      }
      .rail-hint {
        font-family: var(--font-mono); font-size: 9px;
        color: rgba(138,131,113,0.7); margin-top: 1px; letter-spacing: 0.03em;
      }
      .rail-dots {
        position: absolute; top: 0; right: 0; bottom: 0; width: 4px;
        background-image: repeating-linear-gradient(
          to bottom,
          transparent 0px, transparent 6px,
          rgba(181,23,92,0.45) 6px, rgba(181,23,92,0.45) 8px
        );
        pointer-events: none;
      }
      .content { margin-left: 76px; flex: 1; min-width: 0; padding: 2rem 2.5rem; }
      .rail-menu { display: none; }

      /* Keyboard hints are desktop-only (tablets are touch-first too) */
      @media (max-width: 1023px) {
        .rail-hint { display: none; }
      }

      @media (max-width: 767px) {
        /* Rail becomes a fixed TOP bar: brand · spacer · sync · hamburger */
        .rail {
          top: 0; right: 0; bottom: auto; left: 0; width: 100%;
          height: calc(56px + env(safe-area-inset-top));
          flex-direction: row; align-items: center;
          padding: env(safe-area-inset-top) 10px 0; gap: 8px;
          border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .rail-brand { margin: 0; display: flex; align-items: center; }
        .rail-link, .rail-dots { display: none; }
        .content { margin-left: 0; padding: calc(56px + env(safe-area-inset-top) + 1rem) 1rem 1.5rem; }

        .rail-menu { display: block; }
        .rail-menu summary {
          list-style: none; display: flex; align-items: center; justify-content: center;
          width: 44px; height: 44px; border-radius: 6px; cursor: pointer;
          color: var(--color-greige);
        }
        .rail-menu summary::-webkit-details-marker { display: none; }
        .rail-menu[open] summary { background: rgba(181,23,92,0.15); color: var(--color-dye); }
        .menu-panel {
          position: fixed; top: calc(56px + env(safe-area-inset-top)); left: 0; right: 0;
          background: var(--color-ink);
          border-bottom: 1px solid rgba(255,255,255,0.1);
          box-shadow: 0 16px 32px rgba(0,0,0,0.35);
          padding: 6px 8px 10px;
          display: flex; flex-direction: column; gap: 2px;
        }
        .menu-link {
          display: flex; align-items: center; gap: 12px;
          min-height: 48px; padding: 0 12px; border-radius: 6px; text-decoration: none;
          font-family: var(--font-sans); font-size: 13px; font-weight: 600;
          letter-spacing: 0.05em; text-transform: uppercase;
        }
      }
    </style>

    {/* HOTKEYS */}
    <script>
      // "/" focuses first search input (skip when typing in form fields)
      function isTyping(e: KeyboardEvent): boolean {
        const t = e.target as HTMLElement;
        return (
          t.tagName === 'INPUT' ||
          t.tagName === 'TEXTAREA' ||
          t.tagName === 'SELECT' ||
          t.isContentEditable
        );
      }

      let gChordTimeout: ReturnType<typeof setTimeout> | null = null;
      let waitingForG = false;

      const gMap: Record<string, string> = {
        p: '/',
        v: '/venta',
        i: '/ingreso',
        c: '/clientes',
        g: '/gastos',
        o: '/configuracion',
      };

      document.addEventListener('keydown', (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;

        if (e.key === '/' && !isTyping(e)) {
          e.preventDefault();
          const el = document.querySelector<HTMLElement>('[data-hotkey-search]');
          el?.focus();
          return;
        }

        if (waitingForG) {
          waitingForG = false;
          if (gChordTimeout) clearTimeout(gChordTimeout);
          const dest = gMap[e.key.toLowerCase()];
          if (dest) {
            e.preventDefault();
            location.href = dest;
          }
          return;
        }

        if (e.key.toLowerCase() === 'g' && !isTyping(e)) {
          waitingForG = true;
          gChordTimeout = setTimeout(() => { waitingForG = false; }, 900);
        }
      });
    </script>

    {/* PWA registration */}
    <script>
      try {
        // @ts-ignore — virtual module provided by @vite-pwa/astro
        import('virtual:pwa-register').then((m: any) => m.registerSW?.({ immediate: true }));
      } catch {}
    </script>
  </body>
</html>
