# Copy to .env and fill in. NEVER commit .env.
COUCH_USER=            # CouchDB server admin
COUCH_PASS=
APP_USER=              # first application user (gets APP_ROLE)
APP_PASS=
APP_DB=crm             # application database name (must match brand.mjs dbName)
APP_ROLE=crm           # role required to read/write it
COUCH_URL=             # e.g. https://app.example.com/db (required by couch/setup.sh)
